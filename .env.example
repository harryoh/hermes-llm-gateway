# Container user uid/gid — set these to your host user's `id -u` / `id -g` so
# bind-mounted Claude/Codex credential dirs are writable from the container.
# Defaults to 1000; uncomment and adjust if `id -u` differs, then rebuild.
# HOST_UID=1000
# HOST_GID=1000

# Local-only development:
HERMES_ALLOW_INSECURE_DEV=1
GATEWAY_API_KEY=

# Production / LAN exposure:
# HERMES_ALLOW_INSECURE_DEV=0
# GATEWAY_API_KEY=change-me

HERMES_STATE_DIR=/state
HERMES_WORK_DIR=/work
CLAUDE_ACCOUNT_BASE=/accounts/claude
CODEX_ACCOUNT_BASE=/accounts/codex
ACTIVE_CLAUDE_ACCT=acct1

# Optional Telegram notifications
# TG_BOT_TOKEN=
# TG_CHAT_ID=

# Phase 3 DGX extension
# DGX_BASE=http://dgx:8000/v1
# LOCAL_LLM_KIND=vllm
